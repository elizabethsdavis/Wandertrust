# PackPal Cloud Functions config — copy to `functions/.env` before deploying.
# Firebase loads this automatically at deploy time. None of these are secret.
#
#   WEBAUTHN_RP_ID   — your site's bare domain (no scheme, no port)
#   WEBAUTHN_RP_NAME — label shown in the OS passkey prompt
#   WEBAUTHN_ORIGIN  — full origin(s), comma-separated
#
# Local dev example:
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=PackPal
WEBAUTHN_ORIGIN=http://localhost:5173
#
# Production example (set to your real domain before deploying):
# WEBAUTHN_RP_ID=packpal.vercel.app
# WEBAUTHN_RP_NAME=PackPal
# WEBAUTHN_ORIGIN=https://packpal.vercel.app,http://localhost:5173
