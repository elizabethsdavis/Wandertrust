# ─────────────────────────────────────────────────────────────
# PackPal environment — Firebase
#
# Copy this file to `.env.local` and fill in from your Firebase project:
#   Firebase console → Project settings → General → "Your apps" → SDK setup
#   (the firebaseConfig object). Each field maps 1:1 below.
#
# Leave these BLANK to run PackPal fully offline on localStorage
# (no accounts, no cloud sync). The app builds and runs either way.
# ─────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional — only if you deploy your Cloud Functions to a non-default region.
# VITE_FIREBASE_FUNCTIONS_REGION=us-central1
